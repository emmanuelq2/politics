# Légifrance / PISTE API credentials
# Register at https://piste.gouv.fr/registration
# Authentification tab > API Keys section > Générer
PISTE_API_KEY=your_api_key_here
# Authentification tab > Identifiants OAuth section > Générer
PISTE_CLIENT_ID=your_client_id_here
PISTE_CLIENT_SECRET=your_client_secret_here

# Set to true to use the sandbox environment (separate credentials)
PISTE_SANDBOX=false

# Cache TTL in seconds (default 86400 = 24 hours)
PISTE_CACHE_TTL=86400
